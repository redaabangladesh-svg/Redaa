# Supabase Database Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Cloudflare R2 (Storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=product-images
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# Payment Gateways (SSLCommerz)
SSL_STORE_ID=your-sslcommerz-store-id
SSL_STORE_PASSWORD=your-sslcommerz-store-password
SSL_IS_LIVE=false
# Set to "true" once the two SSL_* keys above are real — controls whether the
# online-payment option even appears at checkout.
NEXT_PUBLIC_SSL_ENABLED=false

# Payment Gateways (AmarPay)
AMARPAY_STORE_ID=your-amarpay-store-id
AMARPAY_SIGNATURE_KEY=your-amarpay-signature-key

# Courier Services (Pathao)
PATHAO_CLIENT_ID=your-pathao-client-id
PATHAO_CLIENT_SECRET=your-pathao-client-secret
PATHAO_USERNAME=your-pathao-username
PATHAO_PASSWORD=your-pathao-password
PATHAO_STORE_ID=your-pathao-store-id

# Courier Services (Steadfast)
STEADFAST_API_KEY=your-steadfast-api-key
STEADFAST_SECRET_KEY=your-steadfast-secret-key

# Courier Services (Redex)
REDEX_API_TOKEN=your-redex-api-token

# SMS Gateway (Muthofon)
MUTHOFON_API_KEY=your-muthofon-api-key
SMS_SENDER_ID=your-sms-sender-id

# App Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME="BD Home Decor"
NEXT_PUBLIC_STORE_PHONE="01712345678"
